# ======================================================================
# UrbanFlow Technologies - Variables de entorno (ejemplo)
# Copiar a .env :  cp .env.example .env
# ======================================================================

# --- Kafka / Redpanda ---
KAFKA_BROKERS=redpanda:9092
KAFKA_CLIENT_ID=urbanflow

# --- PostgreSQL (pagos + auditoría + sharing) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=urbanflow
POSTGRES_PASSWORD=urbanflow_secret
POSTGRES_DB=urbanflow

# --- TimescaleDB (telemetría GPS time-series) ---
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432
TIMESCALE_USER=urbanflow
TIMESCALE_PASSWORD=urbanflow_secret
TIMESCALE_DB=telemetry

# --- Neo4j (grafo de rutas) ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=urbanflow_secret

# --- Redis (cache realtime + disponibilidad) ---
REDIS_URL=redis://redis:6379

# --- Puertos de servicios (expuestos en host) ---
GATEWAY_PORT=8080
ROUTE_PLANNING_PORT=3001
TRACKING_PORT=3002
PAYMENT_PORT=3003
TRAFFIC_SIGNAL_PORT=3004
SHARING_PORT=3005
CONGESTION_PORT=3006
NOTIFICATION_PORT=3007
ANALYTICS_PORT=3008
AUDIT_PORT=3009
DASHBOARD_PORT=8090

# --- Observabilidad ---
LOG_LEVEL=info
